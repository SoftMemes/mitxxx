---
import { siteConfig } from '../config';

const { contactEmail, githubUrl } = siteConfig;
const year = new Date().getFullYear();
---

<footer>
  <div class="container">
    <p class="disclaimer">
      MITxxx is an unofficial, community-built app and is not affiliated
      with, endorsed by, or sponsored by MIT or MIT OpenLearning.
    </p>
    <nav class="links" aria-label="Footer">
      <a href="/privacy">Privacy Policy</a>
      {githubUrl && <a href={githubUrl}>GitHub</a>}
      <a href={`mailto:${contactEmail}`}>Contact</a>
    </nav>
    <p class="copy">&copy; {year} MITxxx</p>
  </div>
</footer>

<style>
  footer {
    background: var(--bg-muted);
    border-top: 1px solid var(--border);
    padding: 40px 0;
    color: var(--ink-muted);
    font-size: 0.9rem;
    text-align: center;
  }

  .disclaimer {
    max-width: 56ch;
    margin: 0 auto 20px;
  }

  .links {
    display: flex;
    flex-wrap: wrap;
    gap: 20px;
    justify-content: center;
    margin-bottom: 16px;
  }

  .links a {
    color: var(--ink-muted);
  }

  .copy {
    margin: 0;
  }
</style>
