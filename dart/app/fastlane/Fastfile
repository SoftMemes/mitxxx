default_platform(:ios)

# ── Bundle identifiers ──────────────────────────────────────────────────────

DEV_BUNDLE_ID  = "app.omnilect.dev"
PROD_BUNDLE_ID = "app.omnilect"

# ── Shared helpers ──────────────────────────────────────────────────────────

# Seconds since 2020-01-01 UTC. Offsetting from 2020 keeps the value ~200M today
# vs ~1.78B for raw Unix time, leaving ~60 years before hitting Android's signed
# int32 versionCode ceiling. The loop halves precision if we ever get close
# (won't happen until ~2086). Allows override via BUILD_NUMBER env var.
def compute_build_number
  return ENV["BUILD_NUMBER"].to_i if ENV["BUILD_NUMBER"] && !ENV["BUILD_NUMBER"].empty?

  epoch_2020 = 1_577_836_800
  android_max = 2_100_000_000
  raw = Time.now.to_i - epoch_2020
  raw /= 10 while raw > android_max
  raw
end

def app_store_connect_api_key_config
  app_store_connect_api_key(
    key_id:        ENV.fetch("ASC_KEY_ID"),
    issuer_id:     ENV.fetch("ASC_ISSUER_ID"),
    key_filepath:  ENV.fetch("ASC_KEY_FILEPATH"),
    duration:      1200,
    in_house:      false,
  )
end

# `bundle exec fastlane` constrains GEM_PATH to gems in our Gemfile, which
# prevents Flutter's child `pod` invocation from loading its own dependencies
# ("CocoaPods is installed but broken"). Run flutter outside the bundler env
# so pod sees the system/rbenv gems it was installed against.
def sh_unbundled(cmd)
  Bundler.with_unbundled_env { sh(cmd) }
end

def flutter_build_apk(flavor:, target:)
  bn = compute_build_number
  UI.message("Build number: #{bn}")
  sh_unbundled "fvm flutter build apk --flavor #{flavor} --target #{target} --release --build-number=#{bn}"
end

def flutter_build_appbundle(flavor:, target:)
  bn = compute_build_number
  UI.message("Build number: #{bn}")
  sh_unbundled "fvm flutter build appbundle --flavor #{flavor} --target #{target} --release --build-number=#{bn}"
end

def flutter_build_ipa(flavor:, target:, export_options:)
  bn = compute_build_number
  UI.message("Build number: #{bn}")
  plist_abs = File.expand_path("../ios/#{export_options}", __dir__)
  sh_unbundled "cd #{File.expand_path('..', __dir__)} && fvm flutter build ipa --flavor #{flavor} --target #{target} --release --build-number=#{bn} --export-options-plist=#{plist_abs}"
end

# ── Lane: setup_match ───────────────────────────────────────────────────────
# One-off bootstrap: creates / fetches all certificates and provisioning
# profiles needed by both flavors. Run this once per machine, and any time
# a new device or app identifier is added.
#
# CI lanes below call `match` with readonly: true so they never mutate the
# certificates repo.

lane :setup_match do
  api_key = app_store_connect_api_key_config

  # Dev flavor — distributed via Firebase App Distribution (ad-hoc) and
  # also needs a development profile for local debug builds on devices.
  match(
    type:           "development",
    app_identifier: DEV_BUNDLE_ID,
    api_key:        api_key,
  )
  match(
    type:                    "adhoc",
    app_identifier:          DEV_BUNDLE_ID,
    api_key:                 api_key,
    force_for_new_devices:   true,
  )

  # Prod flavor — App Store / TestFlight, plus a development profile for
  # local debug runs against the production bundle id.
  match(
    type:           "development",
    app_identifier: PROD_BUNDLE_ID,
    api_key:        api_key,
  )
  match(
    type:           "appstore",
    app_identifier: PROD_BUNDLE_ID,
    api_key:        api_key,
  )
end

# ── Lane: dev_distribute ─────────────────────────────────────────────────────
# Builds the dev flavor and uploads to Firebase App Distribution.
# Prereq: firebase apps registered, firebase_options_dev.dart populated.
#
# Lanes:
#   dev_distribute          — both Android and iOS
#   dev_distribute_android  — Android only
#   dev_distribute_ios      — iOS only

def dev_release_notes(options)
  options[:notes] || "Dev build — #{Time.now.strftime('%Y-%m-%d %H:%M')}"
end

def dev_distribute_android_impl(options)
  flutter_build_apk(
    flavor: "dev",
    target: "lib/main_dev.dart",
  )
  firebase_app_distribution(
    app:              ENV.fetch("FIREBASE_ANDROID_DEV_APP_ID"),
    apk_path:         "build/app/outputs/flutter-apk/app-dev-release.apk",
    groups:           "internal",
    release_notes:    dev_release_notes(options),
  )
end

def dev_distribute_ios_impl(options)
  match(
    type:           "adhoc",
    app_identifier: DEV_BUNDLE_ID,
    api_key:        app_store_connect_api_key_config,
    readonly:       true,
  )
  flutter_build_ipa(
    flavor:         "dev",
    target:         "lib/main_dev.dart",
    export_options: "ExportOptions-dev.plist",
  )
  firebase_app_distribution(
    app:              ENV.fetch("FIREBASE_IOS_DEV_APP_ID"),
    ipa_path:         "build/ios/ipa/MITxxx (dev).ipa",
    groups:           "internal",
    release_notes:    dev_release_notes(options),
  )
end

lane :dev_distribute do |options|
  # Compute once so Android + iOS share the same build number within this run.
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  dev_distribute_android_impl(options)
  dev_distribute_ios_impl(options)
end

lane :dev_distribute_android do |options|
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  dev_distribute_android_impl(options)
end

lane :dev_distribute_ios do |options|
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  dev_distribute_ios_impl(options)
end

# ── Lane: beta ───────────────────────────────────────────────────────────────
# Builds the prod flavor and uploads to TestFlight (internal) + Play Store internal track.
#
# Lanes:
#   beta          — both Android and iOS
#   beta_android  — Android only
#   beta_ios      — iOS only

def beta_android_impl
  flutter_build_appbundle(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_play_store(
    track:          "internal",
    release_status: "draft",
    aab:            "build/app/outputs/bundle/prodRelease/app-prod-release.aab",
    json_key:       ENV.fetch("PLAY_STORE_JSON_KEY"),
    package_name:   PROD_BUNDLE_ID,
    skip_upload_metadata:    true,
    skip_upload_images:      true,
    skip_upload_screenshots: true,
  )
end

def testflight_changelog
  sha = (sh("git rev-parse --short HEAD").strip rescue "unknown")
  "Build #{ENV['BUILD_NUMBER']} (#{sha}) — #{Time.now.strftime('%Y-%m-%d %H:%M')}"
end

def beta_ios_impl
  api_key = app_store_connect_api_key_config
  match(
    type:           "appstore",
    app_identifier: PROD_BUNDLE_ID,
    api_key:        api_key,
    readonly:       true,
  )
  flutter_build_ipa(
    flavor:         "prod",
    target:         "lib/main_prod.dart",
    export_options: "ExportOptions-prod.plist",
  )
  upload_to_testflight(
    api_key:                api_key,
    app_identifier:         PROD_BUNDLE_ID,
    ipa:                    "build/ios/ipa/MITxxx.ipa",
    groups:                 ["internal"],
    changelog:              testflight_changelog,
    beta_app_description:   "General bugs and stability",
    beta_app_feedback_email: "contact@omnilect.app",
    skip_waiting_for_build_processing: false,
  )
end

lane :beta do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  beta_android_impl
  beta_ios_impl
end

lane :beta_android do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  beta_android_impl
end

lane :beta_ios do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  beta_ios_impl
end

# ── Lane: release ─────────────────────────────────────────────────────────────
# Submits the prod flavor to App Store + Play Store production.
#
# Lanes:
#   release          — both Android and iOS
#   release_android  — Android only
#   release_ios      — iOS only

def release_android_impl
  flutter_build_appbundle(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_play_store(
    track:         "production",
    aab:           "build/app/outputs/bundle/prodRelease/app-prod-release.aab",
    json_key:      ENV.fetch("PLAY_STORE_JSON_KEY"),
    package_name:  PROD_BUNDLE_ID,
    # Descriptions / changelogs still skipped (not produced by the
    # screenshot compositor). Screenshots + images uploaded from
    # fastlane/metadata/android/, produced by
    # python-tools/screenshot-composer/cli.py --sync-fastlane.
    skip_upload_metadata:    true,
    skip_upload_changelogs:  true,
    skip_upload_images:      false,
    skip_upload_screenshots: false,
  )
end

def release_ios_impl
  api_key = app_store_connect_api_key_config
  match(
    type:           "appstore",
    app_identifier: PROD_BUNDLE_ID,
    api_key:        api_key,
    readonly:       true,
  )
  flutter_build_ipa(
    flavor:         "prod",
    target:         "lib/main_prod.dart",
    export_options: "ExportOptions-prod.plist",
  )
  upload_to_testflight(
    api_key:                 api_key,
    app_identifier:          PROD_BUNDLE_ID,
    ipa:                     "build/ios/ipa/MITxxx.ipa",
    groups:                  ["internal"],
    changelog:               testflight_changelog,
    beta_app_description:    "General bugs and stability",
    beta_app_feedback_email: "contact@omnilect.app",
    submit_beta_review:      true,
  )
  # Upload App Store screenshots (no binary, no description). Fails fast
  # if the App Store listing does not yet exist — that is expected while
  # the iOS store page is "coming soon"; comment this out or run the
  # standalone `upload_screenshots` lane (iOS part skipped) until the
  # listing is provisioned.
  deliver(
    api_key:                          api_key,
    app_identifier:                   PROD_BUNDLE_ID,
    skip_binary_upload:               true,
    skip_metadata:                    true,
    skip_screenshots:                 false,
    force:                            true,
    overwrite_screenshots:            true,
    precheck_include_in_app_purchases: false,
  )
end

lane :release do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  release_android_impl
  release_ios_impl
end

lane :release_android do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  release_android_impl
end

lane :release_ios do
  ENV["BUILD_NUMBER"] = compute_build_number.to_s
  release_ios_impl
end

# ── Lane: upload_screenshots ─────────────────────────────────────────────────
# Push packaged marketing screenshots to both stores without touching the
# binary or app descriptions. Run after
#   python3 python-tools/screenshot-composer/cli.py --sync-fastlane
# has populated fastlane/metadata/.
#
# iOS half is a soft failure path — `deliver` errors if the App Store
# listing does not yet exist. The Play half runs first so the Android
# screenshots publish even if iOS is not provisioned.

lane :upload_screenshots do
  supply(
    json_key:                ENV.fetch("PLAY_STORE_JSON_KEY"),
    package_name:            PROD_BUNDLE_ID,
    skip_upload_apk:         true,
    skip_upload_aab:         true,
    skip_upload_metadata:    true,
    skip_upload_changelogs:  true,
    skip_upload_images:      false,
    skip_upload_screenshots: false,
    validate_only:           false,
  )
  begin
    deliver(
      api_key:                          app_store_connect_api_key_config,
      app_identifier:                   PROD_BUNDLE_ID,
      skip_binary_upload:               true,
      skip_metadata:                    true,
      skip_screenshots:                 false,
      force:                            true,
      overwrite_screenshots:            true,
      precheck_include_in_app_purchases: false,
    )
  rescue => e
    UI.important("deliver (App Store) failed: #{e.message}")
    UI.important("Skipping iOS screenshot upload — listing may not yet exist.")
  end
end
