default_platform(:ios)

# ── Shared helpers ──────────────────────────────────────────────────────────

def app_store_connect_api_key_config
  app_store_connect_api_key(
    key_id:        ENV.fetch("ASC_KEY_ID"),
    issuer_id:     ENV.fetch("ASC_ISSUER_ID"),
    key_filepath:  ENV.fetch("ASC_KEY_FILEPATH"),
    duration:      1200,
    in_house:      false,
  )
end

def flutter_build_apk(flavor:, target:)
  sh "fvm flutter build apk --flavor #{flavor} --target #{target} --release"
end

def flutter_build_appbundle(flavor:, target:)
  sh "fvm flutter build appbundle --flavor #{flavor} --target #{target} --release"
end

def flutter_build_ipa(flavor:, target:)
  sh "fvm flutter build ipa --flavor #{flavor} --target #{target} --release"
end

# ── Lane: dev_distribute ─────────────────────────────────────────────────────
# Builds the dev flavor and uploads to Firebase App Distribution (Android + iOS).
# Prereq: firebase apps registered, firebase_options_dev.dart populated.

lane :dev_distribute do |options|
  # ── Android ──
  flutter_build_apk(
    flavor: "dev",
    target: "lib/main_dev.dart",
  )
  firebase_app_distribution(
    app:              ENV.fetch("FIREBASE_ANDROID_DEV_APP_ID"),
    apk_path:         "../build/app/outputs/flutter-apk/app-dev-release.apk",
    groups:           "internal",
    release_notes:    options[:notes] || "Dev build — #{Time.now.strftime('%Y-%m-%d %H:%M')}",
    firebase_cli_path: `which firebase`.strip,
  )

  # ── iOS ──
  flutter_build_ipa(
    flavor: "dev",
    target: "lib/main_dev.dart",
  )
  firebase_app_distribution(
    app:              ENV.fetch("FIREBASE_IOS_DEV_APP_ID"),
    ipa_path:         "../build/ios/ipa/MITxxx.ipa",
    groups:           "internal",
    release_notes:    options[:notes] || "Dev build — #{Time.now.strftime('%Y-%m-%d %H:%M')}",
    firebase_cli_path: `which firebase`.strip,
  )
end

# ── Lane: beta ───────────────────────────────────────────────────────────────
# Builds the prod flavor and uploads to TestFlight (internal) + Play Store internal track.

lane :beta do |options|
  api_key = app_store_connect_api_key_config

  # ── Android ──
  flutter_build_appbundle(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_play_store(
    track:         "internal",
    aab:           "../build/app/outputs/bundle/prodRelease/app-prod-release.aab",
    json_key:      ENV.fetch("PLAY_STORE_JSON_KEY"),
    package_name:  "app.omnilect",
    skip_upload_metadata: true,
    skip_upload_images:   true,
    skip_upload_screenshots: true,
  )

  # ── iOS ──
  flutter_build_ipa(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_testflight(
    api_key:          api_key,
    ipa:              "../build/ios/ipa/MITxxx.ipa",
    skip_waiting_for_build_processing: true,
  )
end

# ── Lane: release ─────────────────────────────────────────────────────────────
# Submits the prod flavor to App Store + Play Store production.

lane :release do |options|
  api_key = app_store_connect_api_key_config

  # ── Android ──
  flutter_build_appbundle(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_play_store(
    track:         "production",
    aab:           "../build/app/outputs/bundle/prodRelease/app-prod-release.aab",
    json_key:      ENV.fetch("PLAY_STORE_JSON_KEY"),
    package_name:  "app.omnilect",
    skip_upload_metadata: true,
    skip_upload_images:   true,
    skip_upload_screenshots: true,
  )

  # ── iOS ──
  flutter_build_ipa(
    flavor: "prod",
    target: "lib/main_prod.dart",
  )
  upload_to_testflight(
    api_key:              api_key,
    ipa:                  "../build/ios/ipa/MITxxx.ipa",
    submit_beta_review:   true,
  )
end
