# Copy to fastlane/.env (never commit .env) and fill in values.

# ── App Store Connect API key ─────────────────────────────────────────────────
# Generate at: App Store Connect → Users & Access → Integrations → API Keys
ASC_KEY_ID=XXXXXXXXXX
ASC_ISSUER_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
ASC_KEY_FILEPATH=~/.fastlane/keys/AuthKey_XXXXXXXXXX.p8

# ── Google Play service account ───────────────────────────────────────────────
# Create at: Google Cloud Console → IAM → Service Accounts → download JSON
# Grant "Release Manager" in Play Console → Setup → API access
PLAY_STORE_JSON_KEY=~/.fastlane/play-service-account.json

# ── Firebase App Distribution ─────────────────────────────────────────────────
# Get from: Firebase Console → Project Settings → Your Apps → App ID
# (Fill in after running: firebase apps:create ANDROID app.omnilect.dev --project mitxxx-f8b17)
FIREBASE_ANDROID_DEV_APP_ID=1:478154015759:android:REPLACE_AFTER_REGISTRATION
FIREBASE_IOS_DEV_APP_ID=1:478154015759:ios:REPLACE_AFTER_REGISTRATION

# ── Fastlane match (iOS code signing) ────────────────────────────────────────
# Create a private GitHub repo (e.g. kristian-freed/match-certs), then run:
#   cd dart/app && bundle exec fastlane match init
MATCH_GIT_URL=git@github.com:kristian-freed/match-certs.git
MATCH_PASSWORD=choose_a_strong_passphrase
