# Copy to .integration.env (gitignored via the repo-root *.env pattern) and
# fill in credentials for a DEDICATED MITx account used only by the
# integration harness.
#
# The `flows` run clears the app via `adb uninstall` before every launch,
# then performs a real login + real sync. Do NOT point this at a personal
# account with curated lists — the swap-selection step will replace the
# account's selected lists.

# Keycloak credentials for the test account.
INTEGRATION_EMAIL=integration@example.com
INTEGRATION_PASSWORD=replace-me

# Comma-separated display names of MIT Learn lists to tick during the
# initial list-selection step.
#
# Pick lists that together resolve to >= 2 distinct course tiles on My
# Courses. The flows test asserts baseline tile count >= 2 as a regression
# guard against the "favourites-courses-missing-on-first-sync" bug. Mixing
# an enrolled list (for MITx tiles) with a userlist that contains an OCW
# course is the strongest signal.
INTEGRATION_LIST_NAMES=My List A,My List B

# Comma-separated display names of the *alternate* list set used by the
# swap-selection step. Must yield a different set of course tiles than
# INTEGRATION_LIST_NAMES — at least one course must be distinct or the
# test will fail step 11.
INTEGRATION_LIST_NAMES_ALT=My List C

# Exact display title of a course tile rendered under INTEGRATION_LIST_NAMES
# on the home screen. The test opens this course's outline.
INTEGRATION_COURSE_TITLE=Example MITx Course 24.09x

# Exact display title of a lecture tile inside the course above. Must match
# the "Lecture <n>" convention and be a lecture the test account can sync
# inside the 15-minute timeout window.
INTEGRATION_LECTURE_TITLE=Lecture 3
